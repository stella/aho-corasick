{
  "name": "@stll/aho-corasick",
  "version": "0.1.4",
  "description": "NAPI-RS bindings to the Rust aho-corasick crate for Node.js/Bun",
  "keywords": [
    "aho-corasick",
    "multi-pattern",
    "napi-rs",
    "native",
    "rust",
    "string-search"
  ],
  "homepage": "https://github.com/stella/aho-corasick#readme",
  "bugs": {
    "url": "https://github.com/stella/aho-corasick/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stella/aho-corasick"
  },
  "files": [
    "dist",
    "index.js"
  ],
  "type": "module",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "restricted"
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "build:wasm": "napi build --platform --target wasm32-wasip1-threads --release",
    "artifacts": "napi artifacts",
    "universal": "napi universal",
    "build:js": "tsdown",
    "prepublishOnly": "napi prepublish -t npm && tsdown",
    "test": "bun test __test__/index.spec.ts",
    "test:props": "bun test __test__/properties.spec.ts",
    "format": "oxfmt . && rustfmt src/lib.rs",
    "lint": "oxlint .",
    "bench": "bun __bench__/speed.ts",
    "bench:speed": "bun __bench__/speed.ts",
    "bench:unicode": "bun __bench__/unicode.ts",
    "bench:correctness": "bun __bench__/correctness.ts",
    "bench:all": "bun __bench__/speed.ts && bun __bench__/unicode.ts && bun __bench__/correctness.ts",
    "bench:install": "cd __bench__ && bun install",
    "bench:download": "bash __bench__/download-corpus.sh"
  },
  "devDependencies": {
    "@emnapi/core": "^1.9.2",
    "@emnapi/runtime": "^1.9.2",
    "@napi-rs/cli": "^3.5.1",
    "@tybys/wasm-util": "^0.10.1",
    "@types/node": "^25.5.0",
    "bun-types": "^1.3.11",
    "emnapi": "^1.9.2",
    "fast-check": "^4.6.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "tsdown": "^0.21.6"
  },
  "optionalDependencies": {
    "@stll/aho-corasick-darwin-arm64": "0.0.2",
    "@stll/aho-corasick-darwin-x64": "0.0.2",
    "@stll/aho-corasick-linux-arm64-gnu": "0.0.2",
    "@stll/aho-corasick-linux-x64-gnu": "0.0.2",
    "@stll/aho-corasick-wasm32-wasi": "0.0.2"
  },
  "napi": {
    "binaryName": "aho-corasick",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "wasm32-wasip1-threads"
    ]
  },
  "engines": {
    "node": ">= 18"
  }
}
