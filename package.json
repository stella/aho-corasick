{
  "name": "@stella/aho-corasick",
  "version": "0.1.0",
  "description": "NAPI-RS bindings to the Rust aho-corasick crate for Node.js/Bun",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stella/aho-corasick"
  },
  "homepage": "https://github.com/stella/aho-corasick#readme",
  "bugs": {
    "url": "https://github.com/stella/aho-corasick/issues"
  },
  "keywords": [
    "aho-corasick",
    "string-search",
    "multi-pattern",
    "napi-rs",
    "native",
    "rust"
  ],
  "main": "lib.js",
  "types": "lib.d.ts",
  "files": [
    "lib.js",
    "lib.d.ts",
    "index.js",
    "index.d.ts"
  ],
  "napi": {
    "binaryName": "aho-corasick",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "x86_64-pc-windows-msvc",
      "wasm32-wasip1-threads"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "artifacts": "napi artifacts",
    "universal": "napi universal",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "bun test",
    "format": "oxfmt . && rustfmt src/lib.rs",
    "lint": "oxlint .",
    "bench": "bun __bench__/speed.ts",
    "bench:speed": "bun __bench__/speed.ts",
    "bench:unicode": "bun __bench__/unicode.ts",
    "bench:correctness": "bun __bench__/correctness.ts",
    "bench:all": "bun __bench__/speed.ts && bun __bench__/unicode.ts && bun __bench__/correctness.ts",
    "bench:install": "cd __bench__ && bun install",
    "bench:download": "bash __bench__/download-corpus.sh"
  },
  "devDependencies": {
    "@emnapi/core": "^1.9.0",
    "@emnapi/runtime": "^1.9.0",
    "@napi-rs/cli": "^3.0.0",
    "@napi-rs/wasm-runtime": "^1.1.1",
    "@tybys/wasm-util": "^0.10.1",
    "@types/node": "^25.5.0",
    "bun-types": "^1.3.10",
    "emnapi": "^1.9.0",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0"
  },
  "engines": {
    "node": ">= 18"
  },
  "optionalDependencies": {
    "@stella/aho-corasick-darwin-arm64": "0.1.0",
    "@stella/aho-corasick-darwin-x64": "0.1.0",
    "@stella/aho-corasick-linux-x64-gnu": "0.1.0",
    "@stella/aho-corasick-linux-arm64-gnu": "0.1.0",
    "@stella/aho-corasick-linux-x64-musl": "0.1.0",
    "@stella/aho-corasick-win32-x64-msvc": "0.1.0"
  }
}
