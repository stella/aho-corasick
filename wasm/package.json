{
  "name": "@stll/aho-corasick-wasm",
  "version": "1.0.0",
  "description": "Exact many-pattern string search for browsers via WebAssembly. Same API as @stll/aho-corasick.",
  "keywords": [
    "aho-corasick",
    "multi-pattern",
    "napi-rs",
    "rust",
    "string-search",
    "wasm"
  ],
  "homepage": "https://github.com/stella/aho-corasick#readme",
  "bugs": {
    "url": "https://github.com/stella/aho-corasick/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stella/aho-corasick.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "module": "dist/wasm.mjs",
  "types": "dist/wasm.d.mts",
  "exports": {
    ".": {
      "types": "./dist/wasm.d.mts",
      "import": "./dist/wasm.mjs"
    },
    "./vite": {
      "types": "./dist/vite.d.mts",
      "import": "./dist/vite.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@napi-rs/wasm-runtime": "^1.1.3"
  },
  "peerDependencies": {
    "vite": ">=5 <10"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  }
}
